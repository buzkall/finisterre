{
  "private": true,
  "type": "module",
  "scripts": {
    "dev:styles": "npx tailwindcss -i resources/css/app.css -o resources/dist/finisterre.css --postcss --watch",
    "build:styles": "npx tailwindcss -i resources/css/app.css -o resources/dist/finisterre.css --postcss --minify",
    "build:purge": "filament-purge -i resources/dist/finisterre.css -o resources/dist/finisterre.css -v 3.x",
    "build:scripts": "esbuild resources/js/finisterre-rich-editor-paste-fix.js --bundle --minify --outfile=resources/dist/finisterre-rich-editor-paste-fix.js",
    "dev": "npm run dev:styles",
    "build": "npm run build:styles && npm run build:purge && npm run build:scripts"
  },
  "devDependencies": {
    "@awcodes/filament-plugin-purge": "^1.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.14",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.45",
    "postcss-import": "^15.1.0",
    "prettier": "^2.7.1",
    "prettier-plugin-tailwindcss": "^0.1.13",
    "tailwindcss": "^3.4.16"
  }
}
